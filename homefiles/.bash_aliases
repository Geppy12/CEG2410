# Navigation
alias ..="cd .."
alias ...="cd ../.."

# Safer file operations
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"

# Better ls commands
alias ll="ls -alF"
alias la="ls -A"
alias l="ls -CF"

# System info
alias myip="curl ifconfig.me"

# Update system
alias update="sudo apt update && sudo apt upgrade -y"
